Cell[TextData[{
 "Narysuj wykres funkcji ",
 Cell[BoxData[
  FormBox[
   RowBox[{"z", "=", 
    FractionBox[
     RowBox[{" ", 
      RowBox[{"x", " ", "+", " ", "y"}]}], 
     RowBox[{"x", " ", "-", " ", "y"}]]}], TraditionalForm]],ExpressionUUID->
  "fead498d-7a0c-ad40-96ca-9bfe42ac2b21"],
 ". Wybierz odpowiedni obszar definiowania. Dodaj zielony styl obramowania \
(nawet je\:015bli nie wygl\:0105da to zbyt \[LSlash]adnie)."
}], "Text",
 CellChangeTimes->{{3.7753182591375303`*^9, 3.775318404074114*^9}, {
  3.7753186884693203`*^9, 3.7753187944796953`*^9}, {3.775319061639553*^9, 
