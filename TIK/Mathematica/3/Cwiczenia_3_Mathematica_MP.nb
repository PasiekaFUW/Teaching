Cell[CellGroupData[{

Cell["Rozdzia\[LSlash] 11: Calculus", "Title",
 CellChangeTimes->{{3.408580259361693*^9, 3.408580270944826*^9}, 
   3.7833438216170473`*^9, 
   3.9855295822748013`*^9},ExpressionUUID->"81208225-96f9-e640-9c1f-\
46630c81be8e"],

Cell["\<\
Oczywi\:015bcie program Mathematica\[RegisteredTrademark] \:015bwietnie radzi \
sobie z rachunkiem r\[OAcute]\:017cniczkowym. Zaczniemy jednak od tematu, kt\
\[OAcute]ry nie jest tak oczywisty\[LongDash]od funkcji zdefiniowanych w \
odcinkach. Nast\:0119pnie wr\[OAcute]cimy do granic i innych zagadnie\:0144 z \
zakresu rachunku r\[OAcute]\:017cniczkowego. Przyk\[LSlash]ady powinny by\
\[CAcute] w wi\:0119kszo\:015bci zrozumia\[LSlash]e same w sobie. W trakcie \
pracy tw\[OAcute]rzcie w\[LSlash]asne zadania i przyk\[LSlash]ady.\
\>", "Text",
 CellChangeTimes->{{3.408580375173115*^9, 3.4085805187896137`*^9}, {
  3.628641504498106*^9, 3.6286415148696404`*^9}, {3.7239325707402782`*^9, 
  3.7239325716628857`*^9}, {3.783343832960973*^9, 3.783343835896838*^9}, {
  3.7833439178124*^9, 3.78334394708449*^9}, {3.9855356264603615`*^9, 
  3.985535638602356*^9}, {3.985671798294011*^9, 
  3.985671799384036*^9}},ExpressionUUID->"5304df45-51fa-454c-b3ce-\
737da7a9f345"],

Cell[BoxData[
 RowBox[{
  RowBox[{"f", "[", "x_", "]"}], ":=", 
  RowBox[{"Piecewise", "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"-", "x"}], "+", "2"}], ",", " ", 
       RowBox[{"x", "\[LessEqual]", "1"}]}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"x", "-", "1"}], ")"}], "2"], ",", " ", 
       RowBox[{"x", ">", "1"}]}], "}"}]}], "}"}], "]"}]}]], "Input",
 CellChangeTimes->{{3.408580524216658*^9, 
  3.4085805968713818`*^9}},ExpressionUUID->"70e940e0-f658-be42-891f-\
d2813c8d1db4"],

Cell[BoxData[
 RowBox[{"f", "[", "x", "]"}]], "Input",
 CellChangeTimes->{{3.408580612093174*^9, 
  3.408580613159494*^9}},ExpressionUUID->"c93071a7-9e4c-a54c-a513-\
c1238b717967"],

Cell["\<\
Funkcja zosta\[LSlash]a zdefiniowana w formacie liniowym, ale po ponownym \
