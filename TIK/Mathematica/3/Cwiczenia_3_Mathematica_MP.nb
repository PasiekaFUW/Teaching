Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", "f", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"f", "[", "x_", "]"}], ":=", 
  RowBox[{"Piecewise", "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"-", "x"}], "+", "2"}], ",", " ", 
       RowBox[{"x", "\[LessEqual]", "1"}]}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"x", "-", "1"}], ")"}], "2"], ",", " ", 
       RowBox[{"x", ">", "1"}]}], "}"}]}], "}"}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.62864193012632*^9, 3.6286419388709917`*^9}, 
   3.723932901796603*^9},ExpressionUUID->"2831f538-2272-c244-a900-\
933f1d4cba18"],

