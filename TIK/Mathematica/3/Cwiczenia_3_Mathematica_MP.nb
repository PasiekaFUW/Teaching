     RowBox[{"Cos", "[", 
      RowBox[{"2", "t"}], "]"}], ",", " ", 
     RowBox[{"Cos", "[", "t", "]"}], ",", " ", 
     RowBox[{"Sin", "[", 
      RowBox[{"3", "t"}], "]"}]}], "}"}], ",", " ", 
   RowBox[{"{", 
    RowBox[{"t", ",", " ", "0", ",", " ", 
     RowBox[{"2", "\[Pi]"}]}], "}"}]}], "]"}]], "Input",
