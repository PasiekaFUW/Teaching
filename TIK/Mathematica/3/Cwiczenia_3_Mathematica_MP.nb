Cell[CellGroupData[{

Cell["Rozdzia\[LSlash] 14: Elementy graficzne", "Title",
 CellChangeTimes->{{3.4089868337897053`*^9, 3.4089868455835867`*^9}, 
   3.783350488536428*^9, 3.9855295933181667`*^9, 
   3.985539660433855*^9},ExpressionUUID->"85d3db90-22cd-cd4e-99cb-\
aaf3307e23e3"],

Cell[TextData[{
 "Jak wspomniano ju\:017c w wielu poprzednich notatkach, mo\:017cliwo\:015bci \
programu Mathematica\[RegisteredTrademark] w zakresie wy\:015bwietlania \
grafiki s\:0105 naprawd\:0119 imponuj\:0105ce. Cz\:0119\:015b\[CAcute] z nich \
poznali\:015bmy dzi\:0119ki wbudowanym poleceniom, takim jak ",
 StyleBox[ButtonBox["Plot",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Plot"],
  FontWeight->"Bold"],
 " i ",
 StyleBox[ButtonBox["Plot3D",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Plot3D"],
  FontWeight->"Bold"],
 ". Ponadto j\:0119zyk Wolfram Language\[Trademark] zawiera zbi\[OAcute]r \
\:201egraphics primitives\[CloseCurlyDoubleQuote]. Jeden z nich, \
prostok\:0105t, zosta\[LSlash] wykorzystany we wcze\:015bniejszym przyk\
\[LSlash]adzie. M\[OAcute]wi\:0105c najpro\:015bciej, s\:0105 to obiekty \
geometryczne, kt\[OAcute]re mo\:017cna dowolnie rozmieszcza\[CAcute] i \
kolorowa\[CAcute].  "
}], "Text",
 CellChangeTimes->{{3.40898692515769*^9, 3.408987058263611*^9}, {
   3.776633288872085*^9, 3.776633297703179*^9}, {3.783350507855411*^9, 
