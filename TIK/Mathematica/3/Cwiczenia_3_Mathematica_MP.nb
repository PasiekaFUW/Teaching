  FormBox[
   RowBox[{"Sin", "[", "x", "]"}], TraditionalForm]],ExpressionUUID->
  "8e2f174e-2458-214b-acac-d1c2da0e65a7"],
 " i ",
 Cell[BoxData[
  FormBox[
   RowBox[{"Cos", "[", "x", "]"}], TraditionalForm]],ExpressionUUID->
  "06b8493a-deb9-4e48-a788-ae7d93afab7e"],
 " zamiast niekt\[OAcute]rych wyraz\[OAcute]w wielomianowych. Jednak ponownie \
poszukujemy \:201ekombinacji liniowej\[CloseCurlyDoubleQuote] podanych wyraz\
\[OAcute]w. Nazwiemy j\:0105 ",
 Cell[BoxData[
 "func2"], "Input",ExpressionUUID->"29b54205-f5d7-bb4e-903a-10e78ca3cc18"],
 ":"
}], "Text",
 CellChangeTimes->{{3.408753795876504*^9, 3.408753823834029*^9}, {
  3.408753918315339*^9, 3.408753945047346*^9}, {3.4087539801569567`*^9, 
