  FontSlant->"Italic"],
 " w funkcji t (lub innego parametru):"
}], "Text",
 CellChangeTimes->{{3.4089267959182034`*^9, 3.408926857968216*^9}, 
   3.7833420742468452`*^9, 3.7833421128416977`*^9, {3.783342794279834*^9, 
