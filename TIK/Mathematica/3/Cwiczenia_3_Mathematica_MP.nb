  RowBox[{"/.", "%"}]], "Input",ExpressionUUID->
  "236d8e26-0f07-604b-b795-4b2b84e6d966"],
 ".  Przypomnijmy, \:017ce ",
 Cell[BoxData["/."], "Input",ExpressionUUID->
  "6371ee15-da29-4247-8fe8-3f28722499e0"],
 " nakazuje programowi Mathematica zast\:0105pi\[CAcute] zmienne liczbami \
znajduj\:0105cymi si\:0119 za strza\[LSlash]kami:"
}], "Text",
 CellChangeTimes->{{3.47455178552144*^9, 3.4745517878880663`*^9}, {
  3.4745520592649317`*^9, 3.474552078152828*^9}, {3.474552222010479*^9, 
  3.4745522451369658`*^9}, {3.474552371097355*^9, 3.474552432409462*^9}, {
  3.783347917932371*^9, 3.783347950324153*^9}, {3.9855391375748043`*^9, 
  3.9855391534533234`*^9}},ExpressionUUID->"ef03bbaf-d8e5-b746-9ede-\
5ed703ace179"],

Cell[BoxData[
 RowBox[{"func3", "=", 
  RowBox[{
   RowBox[{"a", " ", "+", " ", 
    RowBox[{"b", " ", 
     RowBox[{"Sin", "[", 
      RowBox[{"c", " ", "x"}], "]"}]}], "+", " ", "d"}], "/.", 
   "%"}]}]], "Input",
