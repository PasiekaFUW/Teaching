 RowBox[{"FindFit", "[", 
  RowBox[{"somedata", ",", " ", 
   RowBox[{"a", " ", "+", " ", 
    RowBox[{"b", " ", 
     RowBox[{"Sin", "[", 
      RowBox[{"c", " ", "x"}], "]"}]}], "+", " ", "d"}], ",", " ", 
   RowBox[{"{", 
    RowBox[{"a", ",", " ", "b", ",", " ", "c", ",", " ", "d"}], "}"}], ",", 
   " ", "x"}], "]"}]], "Input",
 CellChangeTimes->{{3.474551613546378*^9, 3.4745516249848003`*^9}, {
  3.4745516558983192`*^9, 3.474551671713389*^9}, {3.4745517505937023`*^9, 
  3.474551759605584*^9}},ExpressionUUID->"3fbbce9c-cbeb-da41-8b7f-\
5e72e5d80ea5"],

Cell[TextData[{
 "No dobrze, a jak teraz (w prosty spos\[OAcute]b) odtworzy\[CAcute] t\:0119 \
funkcj\:0119? Wystarczy kreatywnie wykorzysta\[CAcute] operatory",
