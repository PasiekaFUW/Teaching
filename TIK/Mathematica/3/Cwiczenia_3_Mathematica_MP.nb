Cell[TextData[{
 "Jak mo\:017cna si\:0119 domy\:015bli\[CAcute], program Mathematica \
umo\:017cliwia r\[OAcute]wnie\:017c wykre\:015blanie tr\[OAcute]jwymiarowych \
krzywych parametrycznych. Nale\:017cy poda\[CAcute] wyra\:017cenia dla ",
 StyleBox["x",
  FontSlant->"Italic"],
 ", ",
 StyleBox["y",
  FontSlant->"Italic"],
 " i ",
