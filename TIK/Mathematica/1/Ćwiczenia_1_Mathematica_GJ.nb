Cell[TextData[{
 "Zdefiniuj funkcje ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"f", "(", "x", ")"}], "=", 
    RowBox[{"sin", 
     RowBox[{"(", "x", ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "4b25765f-7ce9-451f-ad84-2edbbaa4799b"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"g", "(", "x", ")"}], "=", 
    RowBox[{
     RowBox[{
      RowBox[{"-", ".042"}], 
      SuperscriptBox["x", "2"]}], "+", 
     RowBox[{"1.31", "x"}], "-", "0.05"}]}], TraditionalForm]],ExpressionUUID->
  "20b74715-dd5e-4666-abe0-3b4ffd60c8d6"],
 ". Utw\[OAcute]rz tabel\:0119 warto\:015bci przedstawiaj\:0105c\:0105 ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],ExpressionUUID->
  "13f6fc98-1c8d-49cf-bf12-4b2971b869c5"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{"f", "(", "x", ")"}], TraditionalForm]],ExpressionUUID->
  "a0b96432-4320-4a55-b9e3-159292277f45"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"g", 
    RowBox[{"(", "x", ")"}]}], TraditionalForm]],ExpressionUUID->
  "cbabd31d-6db6-4af7-bbfc-9950d2511e50"],
 " w przedziale ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[Minus]", "1"}], " ", "\[LessEqual]", " ", "x", " ", "\[LessEqual]",
     " ", "4"}], TraditionalForm]],ExpressionUUID->
  "cea7b4f2-350b-401c-80d1-d98c1ad026a2"],
 " z krokiem 0.25. Wykorzystaj funkcj\:0119 TableForm do wy\:015bwietlenia \
wynik\[OAcute]w. Co zauwa\:017casz?"
}], "ItemNumbered",
 CellChangeTimes->{{3.764457777917048*^9, 3.764457987881686*^9}, {
