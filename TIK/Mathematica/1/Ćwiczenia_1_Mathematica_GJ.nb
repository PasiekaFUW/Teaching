 CellLabel->"",ExpressionUUID->"ca2d37f4-2f70-4017-acfc-0a4d2a415832"],

Cell[TextData[{
 "Niekt\[OAcute]re polecenia dzia\[LSlash]aj\:0105 zgodnie z oczekiwaniami na \
macierzach:\n",
 StyleBox["\[CapitalCAcute]wiczenie:", "Subsubsection"],
 " Znajd\:017a 3mat1: oblicz wyznacznik za pomoc\:0105 ",
 Cell[BoxData[
  RowBox[{"Det", "[", "mat1", "]"}]], "Input",ExpressionUUID->
  "a890cf62-4d4a-4a15-9ea5-3194ff15325e"],
 ", a nast\:0119pnie oblicz ",
 Cell[BoxData[
  RowBox[{"MatrixPower", "[", 
   RowBox[{"mat1", ",", "3"}], "]"}]], "Input",ExpressionUUID->
  "22b824b5-6aa1-49f4-a8e0-ecf61e46d56f"],
 ",  czyli trzeci\:0105 pot\:0119g\:0119 macierzy. Przedstaw te wyniki za \
pomoc\:0105 ",
 StyleBox[ButtonBox["MatrixForm",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/MatrixForm"],
  FontWeight->"Bold"],
 ".. Mo\:017cesz te\:017c wpisa\[CAcute] ",
 Cell[BoxData[
  RowBox[{"//", "MatrixForm", " "}]], "Input",ExpressionUUID->
  "44f62812-8674-4344-8986-0d1ee42229f7"],
 "po dowolnym wyra\:017ceniu. Potem znajd\:017a ",
 StyleBox[ButtonBox["Transpose",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Transpose"],
  FontWeight->"Bold"],
 " oraz ",
 StyleBox[ButtonBox["Inverse",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Inverse"],
  FontWeight->"Bold"],
 " of mat2.  "
}], "Text",
 CellChangeTimes->{{3.407718059450109*^9, 3.40771821304364*^9}, {
