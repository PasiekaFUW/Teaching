  3.984545464655271*^9}},ExpressionUUID->"db4425a4-06c7-48d7-a964-\
cf24be31601e"],

Cell[BoxData[
 FractionBox[
  RowBox[{
   RowBox[{"2", 
    SuperscriptBox["x", "2"]}], "-", "3"}], 
  RowBox[{
   SuperscriptBox["x", "2"], "-", 
   RowBox[{"3", "x"}], "+", "2"}]]], "Input",
 CellChangeTimes->{{3.388274148941988*^9, 3.388274169940762*^9}},
 CellLabel->"",ExpressionUUID->"773cb8dd-e8cc-4080-98d8-c3718bf341cc"],

Cell[TextData[{
 StyleBox["\[CapitalCAcute]wiczenie:", "Subsubsection"],
 " Teraz utw\[OAcute]rz nowe kom\[OAcute]rki i popro\:015b program \
Mathematica, aby wykona\[LSlash] kolejno ka\:017cde z poni\:017cszych polece\
\:0144 na poprzednim wyniku:  ",
 StyleBox[ButtonBox["Apart",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Apart"],
  FontWeight->"Bold"],
 ", ",
 StyleBox[ButtonBox["Together",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Together"],
  FontWeight->"Bold"],
 ", ",
 StyleBox[ButtonBox["Expand",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Expand"],
  FontWeight->"Bold"],
 ", ",
 StyleBox[ButtonBox["ExpandAll",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/ExpandAll"],
  FontWeight->"Bold"],
 " and ",
 StyleBox[ButtonBox["Simplify",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Simplify"],
  FontWeight->"Bold"],
 ". (U\:017cyj polecenia pisane wielk\:0105 liter\:0105 w nawiasach \
kwadratowych, a znak % s\[LSlash]u\:017cy do odwo\[LSlash]ania si\:0119 do \
ostatniego wyniku. Zwr\[OAcute]\[CAcute] uwag\:0119, \:017ce ExpandAll pisze \
si\:0119 z wielk\:0105 liter\:0105 \:201eA\[CloseCurlyDoubleQuote], ale bez \
spacji mi\:0119dzy s\[LSlash]owami. Jest to jedno polecenie programu \
Mathematica.)  Zwr\[OAcute]\[CAcute] uwag\:0119 na zmiany koloru podczas \
pisania. Gdy znajdujesz si\:0119 w kom\[OAcute]rce wprowadzania danych, \
program Mathematica zmieni kolor liter z niebieskiego na czarny, gdy tylko \
znajdzie s\[LSlash]owo w swoim s\[LSlash]owniku."
}], "Text",
 CellChangeTimes->{{3.388274176046455*^9, 3.388274183169775*^9}, {
   3.388274236783835*^9, 3.388274276891748*^9}, {3.3882743208083982`*^9, 
   3.3882744186882877`*^9}, {3.388274455347145*^9, 3.388274480638308*^9}, {
   3.388274546809122*^9, 3.3882745686720867`*^9}, {3.783101040908125*^9, 
   3.783101043339024*^9}, {3.783104969004428*^9, 3.783104998280973*^9}, {
   3.783105029595504*^9, 3.78310505824229*^9}, 3.783696383271758*^9, {
   3.9845454983812943`*^9, 3.984545530630155*^9}, 
   3.984555878492668*^9},ExpressionUUID->"3ff3e550-49bf-4942-9702-\
00d1b0bd88be"]
}, Open  ]],

