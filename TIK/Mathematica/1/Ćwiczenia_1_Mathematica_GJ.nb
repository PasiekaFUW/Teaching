 CellChangeTimes->{{3.388355735838148*^9, 3.388355739634362*^9}, {
  3.783174051702427*^9, 3.7831740521253643`*^9}, {3.984551205658349*^9, 
  3.984551209269527*^9}},ExpressionUUID->"cab9c96e-26a4-448d-9f6f-\
6d10e05cff44"],

Cell["\<\
Zdefiniowanie zmiennej przebiega tak, jak mo\:017cna by si\:0119 tego \
spodziewa\[CAcute]. Zdefiniuj zar\[OAcute]wno a, jak i b, u\:017cywaj\:0105c \
\:015brednika do oddzielenia dw\[OAcute]ch warto\:015bci w jednym wierszu. Je\
\:015bli \:015brednik zostanie umieszczony na ko\:0144cu, nie zostanie wy\
\:015bwietlony \:017caden wynik:\
\>", "Text",
 CellChangeTimes->{{3.388355762527643*^9, 3.388355774173366*^9}, {
   3.388356052587676*^9, 3.388356186396263*^9}, 3.388356244121441*^9, {
   3.407714422947369*^9, 3.407714487581155*^9}, {3.783174087313424*^9, 
   3.783174144872541*^9}, {3.783175081190797*^9, 3.783175081469965*^9}, {
   3.984551259876309*^9, 3.9845512641845217`*^9}, {3.984551299034625*^9, 
   3.984551300100027*^9}},ExpressionUUID->"14bff30c-518f-4e3e-b1b7-\
72e6d8ca6311"],

