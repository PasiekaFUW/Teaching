Cell[TextData[{
 "Znajd\:017a wiersz zawieraj\:0105cy wyra\:017cenie ",
 Cell[BoxData[
  SqrtBox["20"]],
  CellChangeTimes->{{3.3882702059483747`*^9, 3.3882702064063263`*^9}, {
   3.984541443665641*^9, 3.98454144456945*^9}},ExpressionUUID->
  "932d9a12-947c-4201-910b-17b5eb5aebde"],
 " napisane inn\:0105 czcionk\:0105. Przesu\:0144 kursor na ten \:201ewiersz \
wprowadzania\[CloseCurlyDoubleQuote], tak aby zmieni\[LSlash] si\:0119 w \
pionow\:0105 kresk\:0119, a nast\:0119pnie kliknij. Nast\:0119pnie \
naci\:015bnij Shift+Return (Mac) lub Shift+Enter (Windows) (zwyk\[LSlash]e \
naci\:015bni\:0119cie klawisza Return powoduje jedynie przesuni\:0119cie \
kursora do nast\:0119pnego wiersza, tak jak w edytorze tekstu):"
}], "Text",
 CellChangeTimes->{{3.388269962280386*^9, 3.388270201333482*^9}, 
   3.407371018952531*^9, {3.409008669190208*^9, 3.4090087165815573`*^9}, {
   3.723854032917234*^9, 3.7238540405500174`*^9}, {3.77765226061112*^9, 
