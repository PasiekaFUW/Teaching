Cell[CellGroupData[{

Cell["Liczby specjalne v2", "Section",
 CellChangeTimes->{{3.4077115263942127`*^9, 3.407711532480205*^9}, {
  3.783172175865837*^9, 3.78317217624988*^9}, {3.984549242211688*^9, 
  3.984549243530944*^9}},ExpressionUUID->"d22678f7-0835-4faf-af33-\
89921610fbc4"],

Cell["\<\
Najpierw znajd\:017a klawisz Esc na klawiaturze. Szybko si\:0119 z nim \
oswoisz. Program Mathematica\[RegisteredTrademark] oznacza go symbolem \
\[AliasIndicator] podczas wy\:015bwietlania kombinacji klawiszy dla symboli. \
Na przyk\[LSlash]ad, aby utworzy\[CAcute] symbol \[Pi], nale\:017cy nacisn\
\:0105\[CAcute] klawisze Esc, p, Esc. Zostanie to r\[OAcute]wnie\:017c \
pokazane jako \[AliasIndicator] p \[AliasIndicator] przy pisaniu. Wypr\
\[OAcute]buj to.\
\>", "Text",
 CellChangeTimes->{{3.4077115452004347`*^9, 3.407711728449697*^9}, 
   3.723854831308929*^9, {3.783172104049472*^9, 3.783172106258926*^9}, {
   3.783172190274334*^9, 3.7831721987873793`*^9}, {3.783172229732522*^9, 
   3.7831722401155024`*^9}, 3.783172416671506*^9, {3.783173770920527*^9, 
   3.783173772152439*^9}, {3.78369671538978*^9, 3.783696737588963*^9}, {
   3.9845493077985287`*^9, 
   3.984549378393505*^9}},ExpressionUUID->"be349b53-7899-48b4-8e75-\
8efc1790c685"],

Cell[TextData[{
 "W przypadku litery \[ExponentialE] zapis wygl\:0105da \
nast\:0119puj\:0105co: \[AliasIndicator] ee \[AliasIndicator]. Podobnie, dla  \
",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ImaginaryI]", "=", 
    SqrtBox[
     RowBox[{"-", "1"}]]}], TraditionalForm]],ExpressionUUID->
  "41c1c1d5-0ae9-4a8d-bdcb-9db293fae6f6"],
 ", nale\:017cy u\:017cy\[CAcute] zapisu \[AliasIndicator] ii \
\[AliasIndicator]. Teraz oblicz warto\:015b\[CAcute] ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{"2", "\[ImaginaryI]\[Pi]"}]], TraditionalForm]],ExpressionUUID->
  "77b30ede-8bad-4c48-aa82-8280c37600c0"],
 ". (Na razie do uzyskania wyk\[LSlash]adnika u\:017cyj palety lub po prostu \
znaku ^ w nawiasach)."
}], "Text",
 CellChangeTimes->{{3.407711735421063*^9, 3.407711971164873*^9}, {
   3.7779757078302*^9, 3.777975712002592*^9}, {3.7831721069559727`*^9, 
   3.783172108483583*^9}, {3.7831722554280653`*^9, 3.7831723330698967`*^9}, 
   3.783172377998047*^9, 3.783696759280057*^9, {3.9845494026130753`*^9, 
   3.984549458698736*^9}, {3.984549506764162*^9, 
   3.984549539296582*^9}},ExpressionUUID->"bcd5af9b-d551-44c9-b950-\
f5148adf70ac"],

Cell[TextData[{
 "W przypadku liter greckich podej\:015bcie jest zasadniczo takie samo, jak w \
przypadku \[Pi]. Dla \[Alpha] wpisz \[AliasIndicator] a \[AliasIndicator]. \
Pierwsza litera sprawdzi si\:0119 w przypadku wielu liter. Dla \[Theta] u\
\:017cyj \[AliasIndicator] th \[AliasIndicator]. Dzia\[LSlash]a \
r\[OAcute]wnie\:017c \[AliasIndicator] q \[AliasIndicator]. (Niestety, litera \
t jest ju\:017c zaj\:0119ta przez \[Tau].)  W nowej kom\[OAcute]rce wpisz ",
 Cell[BoxData[
  RowBox[{"Sin", "[", 
   RowBox[{
    RowBox[{"\[Alpha]", "+", "\[Beta]"}], "//", "TrigExpand"}]}]], "Input",
  ExpressionUUID->"93286adf-bd26-4698-a878-d569d560d642"],
 ". Nast\:0119pnie wypr\[OAcute]buj to dla kilku innych zmiennych z innymi \
funkcjami trygonometrycznymi. (Zauwa\:017c, \:017ce  \:201e//command\
\[CloseCurlyDoubleQuote] dzia\[LSlash]a z wieloma poleceniami. Mo\:017cna go \
u\:017cy\[CAcute] jako dodatek, nawet je\:015bli nie jest to konieczne. W \
szczeg\[OAcute]lno\:015bci //N jest naprawd\:0119 przydatne!)"
}], "Text",
 CellChangeTimes->{{3.4077119762467117`*^9, 3.407712041712397*^9}, {
   3.407712107411787*^9, 3.407712279920607*^9}, {3.47121411511406*^9, 
   3.471214250852262*^9}, {3.491321069824383*^9, 3.491321069973405*^9}, {
   3.597183998996683*^9, 3.597184019629146*^9}, {3.777975770980657*^9, 
   3.777975801163844*^9}, {3.777975848641283*^9, 3.777975867148692*^9}, {
   3.783172109203609*^9, 3.783172114371237*^9}, {3.783172398416562*^9, 
   3.783172487634007*^9}, 3.783173824951552*^9, {3.783187694473777*^9, 
   3.783187740521006*^9}, 3.7836967990374517`*^9, {3.984549711177835*^9, 
   3.984549740316413*^9}, {3.984549771196143*^9, 
   3.9845498069000683`*^9}},ExpressionUUID->"7627dcb5-7efa-4299-b7ce-\
ceec8970a410"],

Cell["\<\
Aby utworzy\[CAcute] symbol \[Infinity], wpisz \[AliasIndicator] inf \
\[AliasIndicator]. Strza\[LSlash]k\:0119, u\:017cywan\:0105 do opcji podczas \
rysowania wykres\[OAcute]w oraz do okre\:015blenia granic, mo\:017cna utworzy\
\[CAcute] za pomoc\:0105 znak\[OAcute]w \:201e->\[CloseCurlyDoubleQuote], my\
\:015blnika i znaku \:201ewi\:0119kszy ni\:017c\[CloseCurlyDoubleQuote]. \
Sprytnie zamieni si\:0119 ona w strza\[LSlash]k\:0119. Wpisz nast\:0119puj\
\:0105ce polecenie: Limit[(1+1/n)^n,n->\[Infinity]].\
\>", "Text",
 CellChangeTimes->{{3.407712287705021*^9, 3.407712488074808*^9}, {
  3.4712140835964212`*^9, 3.471214084913443*^9}, {3.783172115300404*^9, 
  3.78317211722729*^9}, {3.783172513410056*^9, 3.7831725289466953`*^9}, {
  3.783187758118988*^9, 3.783187819778378*^9}, {3.984549904845302*^9, 
  3.98454990556462*^9}, {3.984549970959281*^9, 
  3.9845499750338793`*^9}},ExpressionUUID->"c18dd4ad-a4bc-42cc-bbe2-\
09fca4a03a3d"],

Cell[TextData[{
 StyleBox["\[CapitalCAcute]wiczenie:", "Subsubsection"],
 " Wypr\[OAcute]buj 2 w\[LSlash]asne wyra\:017cenia."
}], "Text",
