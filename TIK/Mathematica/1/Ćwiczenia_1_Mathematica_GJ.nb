  3.9845449828670177`*^9}},ExpressionUUID->"b0e0e4ec-4bdb-44d3-a73e-\
034f34041b7d"],

Cell["\<\
Wykonaj polecenia w ka\:017cdej z poni\:017cszych kom\[OAcute]rek, aby \
zobaczy\[CAcute] niewielkie uproszczenie:\
\>", "Text",
 CellChangeTimes->{{3.38827357521171*^9, 3.38827359049201*^9}, {
   3.783104872942485*^9, 3.783104873093479*^9}, {3.783105192761155*^9, 
   3.783105194961351*^9}, 
   3.984545138594385*^9},ExpressionUUID->"3021e9d8-9ad4-4392-b63d-\
be4fe52fcac6"],

Cell[BoxData[
 RowBox[{
  RowBox[{"3", 
   SuperscriptBox["x", "4"]}], "-", 
  RowBox[{"6", 
   SuperscriptBox["x", "2"]}], "+", "5", "+", 
  RowBox[{"4", 
   SuperscriptBox["x", "2"]}], "-", "3"}]], "Input",
 CellChangeTimes->{{3.3882735959295*^9, 3.388273618588056*^9}},
 CellLabel->"",ExpressionUUID->"f9a01629-7024-4e58-b5e1-e7e5a3f49e3d"],

Cell[BoxData[
 RowBox[{"Simplify", "[", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     RowBox[{"4", 
      SuperscriptBox["x", "3"]}], "+", 
     RowBox[{"5", 
      SuperscriptBox["x", "2"]}], "+", "3"}], ")"}], "-", 
   RowBox[{"3", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"2", 
       SuperscriptBox["x", "2"]}], "-", 
      RowBox[{"6", "x"}], "+", "1"}], ")"}]}]}], "]"}]], "Input",
 CellChangeTimes->{{3.388273644582713*^9, 3.3882736804914637`*^9}},
 CellLabel->"",ExpressionUUID->"fc9e5a86-5fca-4874-bb36-0a8b341543bf"],

Cell[BoxData[
 SuperscriptBox[
  RowBox[{"(", 
   RowBox[{
    RowBox[{"3", "x"}], "+", 
    RowBox[{"2", "y"}]}], ")"}], "8"]], "Input",
 CellChangeTimes->{{3.388273685591832*^9, 3.388273724238104*^9}},
 CellLabel->"",ExpressionUUID->"6560b52b-9735-4fba-ab79-79d141bfcccc"],

Cell["\<\
To ostatnie rozwi\:0105zanie mog\[LSlash]o nie by\[CAcute] tym, czego \
si\:0119 spodziewali\:015bmy - lub czego oczekiwali\:015bmy. Program \
Mathematica dokonuje automatycznego uproszczenia, ale nie rozwinie \
wyra\:017cenia, poniewa\:017c ta posta\[CAcute] zazwyczaj nie jest uznawana \
za uproszczon\:0105. Pole\[CAcute] mu, aby je rozwin\:0105\[LSlash]:\
\>", "Text",
 CellChangeTimes->{{3.388273730112589*^9, 3.388273797129128*^9}, {
  3.783101036515325*^9, 3.783101037314621*^9}, {3.7831048829334307`*^9, 
  3.783104894822357*^9}, {3.783105198104924*^9, 3.7831051989454527`*^9}, {
  3.984545218456205*^9, 3.9845452227981377`*^9}, {3.9845452918531446`*^9, 
  3.984545299894793*^9}},ExpressionUUID->"5433d8a7-efc4-421d-bd72-\
4a6256065b1a"],

Cell[BoxData[
 RowBox[{"Expand", "[", 
  SuperscriptBox[
   RowBox[{"(", 
    RowBox[{
     RowBox[{"3", "x"}], "+", 
     RowBox[{"2", "y"}]}], ")"}], "8"], "]"}]], "Input",
 CellChangeTimes->{{3.388273799367463*^9, 3.388273811114609*^9}},
 CellLabel->"",ExpressionUUID->"116eb027-bad9-406e-9be3-6180163b0182"],

Cell["\<\
Utw\[OAcute]rz now\:0105 kom\[OAcute]rk\:0119 poni\:017cej tej, aby \:201eroz\
\[LSlash]o\:017cy\[CAcute] na czynniki\[CloseCurlyDoubleQuote] ostatni wynik. \
(Pami\:0119taj, \:017ce nazwa polecenia musi by\[CAcute] pisana wielkimi \
literami i konieczne jest u\:017cycie nawias\[OAcute]w kwadratowych. \
U\:017cyj znaku %, aby odwo\[LSlash]a\[CAcute] si\:0119 do ostatniego wyniku \
w postaci rozwini\:0119tej.)\
\>", "Text",
 CellChangeTimes->{{3.388273919280876*^9, 3.388273993468458*^9}, {
   3.783101038011311*^9, 3.783101038747542*^9}, 
   3.984545325668466*^9},ExpressionUUID->"ac4dc3bf-53b1-461a-987d-\
5b92ad45c5d1"],

Cell[TextData[{
 "Teraz przyjrzyjmy si\:0119 jeszcze kilku poleceniom. Rozwa\:017cmy u\
\[LSlash]amek ",
 Cell[BoxData[
  FormBox[
   FractionBox[
    RowBox[{
     RowBox[{"2", 
      SuperscriptBox["x", "2"]}], "-", "3"}], 
    RowBox[{
     SuperscriptBox["x", "2"], "-", 
     RowBox[{"3", "x"}], "+", "2"}]], TraditionalForm]],ExpressionUUID->
  "84e0cd2c-f862-4353-9bde-cb279ef66042"],
 ". Najpierw wprowad\:017a to, uruchamiaj\:0105c kom\[OAcute]rk\:0119, tak \
aby znalaz\[LSlash]a si\:0119 w pami\:0119ci komputera:"
}], "Text",
 CellChangeTimes->{{3.388274003026473*^9, 3.3882740662219477`*^9}, {
  3.388274116513983*^9, 3.3882741456518373`*^9}, {3.6284601088637257`*^9, 
