 CellLabel->"",ExpressionUUID->"c5c40741-a034-4bc6-9dea-e4d91c9cef80"],

Cell["\<\
Teraz jednak zmienimy warto\:015b\[CAcute] b (spowoduje to nadpisanie \
poprzedniej warto\:015bci, ale lepszym rozwi\:0105zaniem jest najpierw \
wyzerowanie poprzedniej warto\:015bci):\
\>", "Text",
