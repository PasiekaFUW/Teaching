Cell[TextData[{
 "W pierwszym samouczku zapoznali\:015bmy si\:0119 z niekt\[OAcute]rymi \
poleceniami algebraicznymi. Teraz przyjrzymy si\:0119 im za pomoc\:0105 \
palety. W sekcji \:201ePolecenia podstawowe\[CloseCurlyDoubleQuote] wybierz \
drugi przycisk: ",
 Cell[BoxData[
  FormBox[
   RowBox[{"y", "=", "x"}], TraditionalForm]],ExpressionUUID->
  "5aff31ab-7726-4d07-9e3c-b441d21149ea"],
 "."
