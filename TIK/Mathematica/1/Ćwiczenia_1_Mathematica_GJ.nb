Cell[TextData[{
 StyleBox["\[CapitalCAcute]wiczenie:", "Subsubsection"],
 " Wr\[OAcute]\[CAcute] do palety. W sekcji \:201ePolecenia podstawowe\
\[CloseCurlyDoubleQuote] wybierz czwarty przycisk \[Dash] ten, kt\[OAcute]ry \
wygl\:0105da jak ma\[LSlash]a macierz! Wiele przycisk\[OAcute]w powinno by\
\[CAcute] intuicyjnych. Zdefiniuj macierz mat3, a nast\:0119pnie kliknij \
podstawow\:0105 macierz 2\[Times]2. Nast\:0119pnie kliknij przycisk \
\:201eDodaj wiersz\[CloseCurlyDoubleQuote] lub \:201eDodaj kolumn\:0119\
\[CloseCurlyDoubleQuote], w zale\:017cno\:015bci od potrzeb. Wype\[LSlash]nij \
pola."
}], "Text",
 CellChangeTimes->{{3.4712167026853657`*^9, 3.471216752710024*^9}, {
