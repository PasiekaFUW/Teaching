 CellLabel->"",ExpressionUUID->"4f8ad8b9-5af2-4507-9a96-aee91651198d"],

Cell["\<\
Chcesz sprawdzi\[CAcute], czy a = b?  W tym celu nale\:017cy \
u\:017cy\[CAcute] podw\[OAcute]jnego znaku r\[OAcute]wno\:015bci:\
\>", "Text",
 CellChangeTimes->{{3.3883563681425467`*^9, 3.388356392012803*^9}, {
   3.783174152367982*^9, 3.783174163009162*^9}, 
   3.984551344374558*^9},ExpressionUUID->"a85bda50-d7b7-465e-9035-\
a6faba58a686"],

