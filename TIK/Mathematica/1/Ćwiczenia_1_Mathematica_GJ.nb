Cell["\<\
No dobrze, Mathematica potrafi wi\:0119c upraszcza\[CAcute] wyra\:017cenia. A \
je\:015bli nie sta\[LSlash]o si\:0119 to praktycznie natychmiast, to dlatego, \
\:017ce przy pierwszym uruchomieniu trzeba za\[LSlash]adowa\[CAcute] inny \
program, zwany \:201ej\:0105drem Mathematica\[CloseCurlyDoubleQuote] \
(kernel). Mo\:017cemy spr\[OAcute]bowa\[CAcute] z innym (ponownie \
naci\:015bnij Shift+Enter lub Enter, aby wykona\[CAcute] polecenie):\
\>", "Text",
 CellChangeTimes->{{3.388270229134345*^9, 3.3882702590455093`*^9}, {
  3.388270308482403*^9, 3.388270367062791*^9}, {3.471209055722973*^9, 
  3.471209059245467*^9}, {3.6284597874607677`*^9, 3.628459788118487*^9}, {
  3.7776522111982527`*^9, 3.777652227938938*^9}, {3.783101015667179*^9, 
  3.783101017547331*^9}, {3.783103960833646*^9, 3.783103986599889*^9}, {
  3.783104819133905*^9, 3.783104829276944*^9}, {3.783105142543717*^9, 
  3.783105149104823*^9}, {3.78369619736829*^9, 3.7836962004165573`*^9}, {
  3.984544044981846*^9, 
  3.98454406728903*^9}},ExpressionUUID->"56c3ba13-cf0d-42f3-b00a-\
dcb1b4b23222"],

