   3.9845478736208477`*^9}, 
   3.984558888747369*^9},ExpressionUUID->"97308891-4cdd-4860-a167-\
70cad04bde98"],

Cell["\<\
W kolejnej kom\[OAcute]rce naci\:015bnij Expand i napisz (x+y)^50. \
Mo\:017cesz te\:017c u\:017cy\[CAcute] palety, aby utworzy\[CAcute] indeks g\
\[OAcute]rny.\
\>", "Text",
 CellChangeTimes->{{3.471213449391522*^9, 3.471213534671545*^9}, 
   3.628461017919744*^9, {3.783171606403151*^9, 3.783171629930745*^9}, 
